{
  "name": "@body-io/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck:app": "tsc -b --noEmit",
    "typecheck:functions": "tsc -p tsconfig.functions.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2025-01-15 --port 8788"
  },
  "dependencies": {
    "@body-io/mcp-server": "*",
    "@body-io/shared": "*",
    "@supabase/supabase-js": "^2.108.2",
    "@zxing/browser": "^0.1.5",
    "dotenv": "^17.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250109.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "2.1.8",
    "wrangler": "3.99.0"
  }
}
